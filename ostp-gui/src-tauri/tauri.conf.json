{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ostp-gui",
  "version": "0.3.15",
  "identifier": "com.ospab.ostp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OSTP",
        "width": 360,
        "height": 680,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Ospab Foundation",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}